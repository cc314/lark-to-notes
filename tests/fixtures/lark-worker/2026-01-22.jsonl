{"source_id": "dm-zhuang-zhen", "source_type": "dm_user", "message_id": "om_x100b582b7b14c0a0e12d36fd562dcab", "chat_id": "ou_4dfe15a5bcafc6e258f66f1438175f63", "chat_type": "unknown", "sender_id": "ou_4dfe15a5bcafc6e258f66f1438175f63", "sender_name": "Zhuang Zhen", "direction": "incoming", "created_at": "2026-01-22 17:52", "content": "```SQL\nSELECT user_id                           AS mgr_user_id\n     , id_number.hashed                  AS hashed_id_number\n     , CAST(gojek_customer_id AS BIGINT) AS gojek_customer_id\n     , credit_application_id             AS gpp_credit_application_id\n     , created_timestamp                 AS gpp_credit_application_time\n     , created_jkt_datetime              AS gpp_credit_appl_created_jkt_datetime\n     , status                            AS gpp_credit_appl_status\n     , app_source                        AS gpp_app_source\n     , IF(app_source in ('GOJEK','GOPAY') AND power_range_rl = '-1', 1, 0) AS is_nwl\n     , IF(status = 'APPROVED', 1, 0)     AS is_gpp_approved\nFROM p_mgr_id_mart.risk.detail_gtf_credit_application_tracking\nWHERE 1 = 1\n  AND credit_application_id IS NOT NULL\n  AND created_timestamp <= end_timestamp()\nlimit 10\n\n```", "payload": {"content": "```SQL\nSELECT user_id                           AS mgr_user_id\n     , id_number.hashed                  AS hashed_id_number\n     , CAST(gojek_customer_id AS BIGINT) AS gojek_customer_id\n     , credit_application_id             AS gpp_credit_application_id\n     , created_timestamp                 AS gpp_credit_application_time\n     , created_jkt_datetime              AS gpp_credit_appl_created_jkt_datetime\n     , status                            AS gpp_credit_appl_status\n     , app_source                        AS gpp_app_source\n     , IF(app_source in ('GOJEK','GOPAY') AND power_range_rl = '-1', 1, 0) AS is_nwl\n     , IF(status = 'APPROVED', 1, 0)     AS is_gpp_approved\nFROM p_mgr_id_mart.risk.detail_gtf_credit_application_tracking\nWHERE 1 = 1\n  AND credit_application_id IS NOT NULL\n  AND created_timestamp <= end_timestamp()\nlimit 10\n\n```", "create_time": "2026-01-22 17:52", "deleted": false, "message_id": "om_x100b582b7b14c0a0e12d36fd562dcab", "msg_type": "post", "sender": {"id": "ou_4dfe15a5bcafc6e258f66f1438175f63", "id_type": "open_id", "name": "Zhuang Zhen", "sender_type": "user", "tenant_key": "1503d1037d07977c"}, "updated": false}}
